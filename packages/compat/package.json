{
	"name": "@buchida/email-compat",
	"version": "0.1.0",
	"description": "Email client CSS compatibility database and checker for @buchida/email",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
