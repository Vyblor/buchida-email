{
	"name": "@buchida/email-cli",
	"version": "0.1.0",
	"description": "CLI for @buchida/email — dev server, build, and export commands",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"buchida-email": "./dist/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@buchida/preview": "workspace:*",
		"@buchida/render": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"typescript": "^5.0.0"
	},
	"files": ["dist", "README.md"],
	"keywords": ["email", "buchida", "cli", "cjk", "templates"],
	"author": "buchida <hello@buchida.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Vyblor/buchida-email.git"
	},
	"homepage": "https://buchida.com/docs/templates",
	"engines": {
		"node": ">=18.0.0"
	}
}
